{
  "name": "central-command",
  "version": "0.1.0",
  "private": true,
  "description": "Personal extensible dashboard built on Electron + React.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Tomer Braff",
    "email": "tomerbraff@gmail.com"
  },
  "scripts": {
    "dev": "electron-vite dev -- --disable-gpu --no-sandbox",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:mobile": "tsc --noEmit -p tsconfig.mobile.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "electron-vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "mobile:sync": "npm run build:mobile && npx cap sync android",
    "mobile:run": "npx cap run android",
    "mobile:dev": "vite --config vite.mobile.config.ts"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^7.4.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.3",
    "@capacitor/core": "^7.4.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/preferences": "^6.0.3",
    "better-sqlite3": "^12.9.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.0",
    "recharts": "^3.8.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "electron": "^40.9.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^6.0.0-beta.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.6"
  }
}
